<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvDashboardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THRIFT!"
                android:textColor="@color/text_main"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDashboardSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="discover secondhand fits"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <!-- SEARCH -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/button_white"
                android:hint="search thrift items"
                android:paddingStart="16dp"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_main" />

            <!-- CATEGORY TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="categories"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <!-- CATEGORY SCROLL -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="all"
                        android:textAllCaps="false"
                        android:background="@drawable/button_yellow"
                        android:textColor="@color/outline"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="hoodies"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_white"
                        android:textColor="@color/outline"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="jackets"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_white"
                        android:textColor="@color/outline"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="shirts"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_white"
                        android:textColor="@color/outline"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="pants"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_white"
                        android:textColor="@color/outline"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- ITEMS TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="latest thrift finds"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <!-- RECYCLER VIEW -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- FLOATING NAV -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/floating_nav_bg"
        android:elevation="6dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_home"
            android:background="@android:color/transparent"
            android:padding="6dp"/>

        <ImageButton
            android:id="@+id/navSwap"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_swap"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:layout_marginStart="16dp"/>

        <ImageButton
            android:id="@+id/navCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_cart"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:layout_marginStart="16dp"/>

        <ImageButton
            android:id="@+id/navProfile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_profile"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:layout_marginStart="16dp"/>

    </LinearLayout>

</FrameLayout>