<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- SCROLLABLE CART ITEMS -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvCartTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="my cart"
                    android:textColor="@color/text_main"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCartSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="items ready for checkout"
                    android:textColor="@color/text_main"
                    android:textSize="14sp" />

                <!-- ITEM 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/rounded_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:background="@color/accent_green"
                        android:contentDescription="@string/app_name"
                        android:padding="16dp"
                        android:scaleType="centerInside"
                        android:src="@mipmap/ic_launcher" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Vintage Oversized Hoodie"
                        android:textColor="@color/text_main"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱850"
                        android:textColor="@color/text_main" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quantity: 1"
                        android:textColor="@color/text_main" />
                </LinearLayout>

                <!-- ITEM 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/rounded_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:background="@color/accent_pink"
                        android:contentDescription="@string/app_name"
                        android:padding="16dp"
                        android:scaleType="centerInside"
                        android:src="@mipmap/ic_launcher" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Retro Denim Jacket"
                        android:textColor="@color/text_main"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱1,100"
                        android:textColor="@color/text_main" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quantity: 1"
                        android:textColor="@color/text_main" />
                </LinearLayout>

                <!-- EXTRA SPACE SO LAST ITEM ISN'T HIDDEN -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />

            </LinearLayout>
        </ScrollView>

        <!-- FIXED ORDER SUMMARY -->
        <LinearLayout
            android:id="@+id/orderSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="74dp"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvOrderSummaryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="order summary"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Subtotal: ₱1,950"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvShipping"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shipping: ₱80"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: ₱2,030"
                android:textColor="@color/text_main"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCheckout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_yellow"
                android:text="checkout"
                android:textAllCaps="false"
                android:textColor="@color/outline"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- FLOATING NAV -->
    <LinearLayout
        android:id="@+id/bottomNavBarCart"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/floating_nav_bg"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/navHomeCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="Home"
            android:padding="6dp"
            android:src="@drawable/ic_home" />

        <ImageButton
            android:id="@+id/navSwapCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:background="@android:color/transparent"
            android:contentDescription="Swap"
            android:padding="6dp"
            android:src="@drawable/ic_swap" />

        <ImageButton
            android:id="@+id/navCartCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:background="@android:color/transparent"
            android:contentDescription="Cart"
            android:padding="6dp"
            android:src="@drawable/ic_cart" />

        <ImageButton
            android:id="@+id/navProfileCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:background="@android:color/transparent"
            android:contentDescription="Profile"
            android:padding="6dp"
            android:src="@drawable/ic_profile" />
    </LinearLayout>

</FrameLayout>